{
  "expo": {
    "name": "CourseUp Mobile",
    "slug": "courseup-mobile",
    "scheme": "courseup-mobile",
    "version": "0.1.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.courseuppro.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#07111B"
      }
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EXPO_PROJECT_ID"
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
